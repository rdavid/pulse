#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2025-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
# Local variables, file not following, variable unused:
#  shellcheck disable=SC1091,SC2034,SC3043
readonly \
	BASE_APP_VERSION=0.9.20260711 \
	CLIENT_HOST="${CLIENT_HOST:-client}" \
	CLIENT_PORT="${CLIENT_PORT:-9090}" \
	DBFILE="${DBFILE:-dat/db}" \
	LISTEN_PORT="${LISTEN_PORT:-8080}" \
	PERIOD=5 \
	TEST_MODE="${TEST_MODE:-false}"
. base.sh

# Validates required commands, initializes the database, and listens in a
# loop.
main() {
	cmd_exists nc || die
	initdb
	log "$(id -nu) is listening on $LISTEN_PORT."
	listenc
}

# Initializes the database by truncating its file.
initdb() {
	iswritable "$DBFILE" || die "Check $DBFILE."
	: >"$DBFILE"
}

# Sends the die message to the client. The client kills its own process
# group when the message arrives.
killc() {
	local msg
	log "Sending the die message to $CLIENT_HOST:$CLIENT_PORT."
	msg="$(printf die\\n | nc 2>&1 "$CLIENT_HOST" "$CLIENT_PORT")" ||
		loge "$msg"
}

# Listens for messages from the client. Triggers a client restart every
# PERIOD iterations.
listenc() {
	local cnt=0 lne
	while :; do
		nc -l -p "$LISTEN_PORT" | {
			IFS= read -r lne
			storedb "$lne"
		}
		cnt=$((cnt + 1))
		log "Stored $cnt times."
		[ "$TEST_MODE" = true ] && cya Terminated in test mode.
		[ $((cnt % PERIOD)) -eq 0 ] && killc
		sleep 1
	done
}

# Appends the first argument to the database with a timestamp.
storedb() {
	[ -n "$1" ] || return 0
	printf '%s %s\n' "$(timestamp)" "$1" >>"$DBFILE"
}

# Entry point.
main "$@"
