#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2025-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
# Local variables, file not following, variable unused:
#  shellcheck disable=SC1091,SC2034,SC3043
readonly \
	BASE_APP_VERSION=0.9.20260711 \
	INTERVAL=5 \
	LISTEN_PORT="${LISTEN_PORT:-9090}" \
	SERVER_HOST="${SERVER_HOST:-server}" \
	SERVER_PORT="${SERVER_PORT:-8080}" \
	TEST_MODE="${TEST_MODE:-false}"
. base.sh

# Validates required commands, starts the listener, and sends data in a
# loop.
main() {
	cmd_exists awk ip nc paste || die
	listens
	log "$(id -nu) is sending data to $SERVER_HOST:$SERVER_PORT."
	sendd
}

# Lists every network interface with its IPv4 address on a single line.
# Each entry has the form "<interface> <IP/CIDR>" and a semicolon separates
# the entries.
iface() {
	ip -o -4 addr show | awk '{print $2, $4}' | paste -sd ';' -
}

# Listens in a background process for the die message and terminates the
# parent process group when it arrives.
listens() {
	local dad="$$"
	(
		local lne
		while :; do
			nc -l -p "$LISTEN_PORT" | {
				IFS= read -r lne
				log "Got $lne."
				[ "$lne" = die ] && kill -- -$dad
			}
			sleep 1
		done
	) &
}

# Sends data to the server every INTERVAL seconds.
sendd() {
	local cnt=0 msg
	while :; do
		msg="$(printf '%s;%s\n' "$(prettyuptime)" "$(iface)" |
			nc 2>&1 "$SERVER_HOST" "$SERVER_PORT")" || loge "$msg"
		cnt=$((cnt + 1))
		log "Sent $cnt times, wait for ${INTERVAL}s."
		[ "$TEST_MODE" = true ] && cya Terminated in test mode.
		sleep "$INTERVAL"
	done
}

# Entry point.
main "$@"
